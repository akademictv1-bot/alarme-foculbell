{
  "expo": {
    "name": "FocusBell",
    "slug": "focusbell",
    "version": "1.0.0",
    "scheme": "focusbell",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "experiments": {
      "reactCompiler": true
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.focusbell.app",
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "remote-notification",
          "fetch",
          "audio",
          "remote-notification",
          "fetch"
        ],
        "UNNotificationPermissionOptions": [
          "alert",
          "badge",
          "sound",
          "alert",
          "badge",
          "sound"
        ]
      }
    },
    "android": {
      "package": "com.focusbell.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#09090b",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/standard.wav",
            "./assets/sounds/urgent.wav",
            "./assets/sounds/emergency.wav",
            "./assets/sounds/sharp.wav",
            "./assets/sounds/pulse.wav"
          ],
          "icon": "./assets/icon.png",
          "color": "#09090b",
          "defaultChannel": "alarm"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#09090b"
        }
      ],
      "expo-router",
      "expo-status-bar",
      "expo-audio",
      "expo-asset"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7659fec2-42bf-4f56-b975-a6cf5d21e83b"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7659fec2-42bf-4f56-b975-a6cf5d21e83b"
    }
  }
}
